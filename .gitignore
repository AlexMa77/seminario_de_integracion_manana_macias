# =========================================================
# MONOREPO GLOBAL .gitignore (RECURSIVO)
# ReactJS / React Native / Kotlin / Python / Django / Flutter
# =========================================================


# =========================================================
# SISTEMA / EDITORES
# =========================================================
**/.DS_Store
**/Thumbs.db


**/.idea/
**/.vscode/
**/*.iml


# =========================================================
# LOGS
# =========================================================
**/*.log
**/logs/


npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# =========================================================
# VARIABLES DE ENTORNO
# =========================================================
**/.env
**/.env.*
!**/.env.example


# =========================================================
# NODE / REACT / REACT NATIVE
# =========================================================
**/node_modules/
**/.pnp/
**/.pnp.js


**/dist/
**/build/
**/coverage/


**/.next/
**/out/


**/.expo/
**/.expo-shared/


**/.turbo/
**/.cache/


**/*.tsbuildinfo


# React Native
**/android/.gradle/
**/android/build/
**/android/app/build/


**/ios/build/
**/ios/Pods/
**/*.xcworkspace


# =========================================================
# KOTLIN / ANDROID
# =========================================================
**/.gradle/
**/build/
**/app/build/
**/captures/
**/local.properties
**/out/


# =========================================================
# PYTHON / DJANGO
# =========================================================
**/__pycache__/
**/*.py[cod]
**/*$py.class


# Entornos virtuales
**/venv/
**/.venv/
**/env/
**/ENV/


# Tooling
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.tox/


# Coverage
**/.coverage
**/htmlcov/


# Django
**/*.sqlite3
**/db.sqlite3
**/media/
**/staticfiles/


# =========================================================
# FLUTTER / DART
# =========================================================
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.packages
**/.pub-cache/
**/.pub/


# Flutter generated
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec


# =========================================================
# FIREBASE / GOOGLE
# =========================================================
**/google-services.json
**/GoogleService-Info.plist


# =========================================================
# CERTIFICADOS / SECRETOS
# =========================================================
**/*.jks
**/*.keystore
**/*.p12
**/*.pem
**/*.key


# =========================================================
# ARCHIVOS TEMPORALES
# =========================================================
**/tmp/
**/temp/
**/.sass-cache/


**/*.swp
**/*.swo
**/*~


# =========================================================
# TESTING
# =========================================================
**/.nyc_output/


# =========================================================
# MONOREPO EXTRA
# =========================================================
**/package-lock.json
**/yarn.lock
**/pnpm-lock.yaml


# Ignora caches de herramientas modernas
**/.nx/
**/.parcel-cache/
**/.eslintcache


# =========================================================
# OPCIONAL (descomenta si quieres ignorar assets pesados)
# =========================================================
# **/*.apk
# **/*.aab
# **/*.ipa
# **/*.apk
# **/*.xcarchive




